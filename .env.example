# Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
# Railway: auto-provided when you add a PostgreSQL plugin — use the
# "DATABASE_URL" variable reference from the plugin, e.g.:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://username:password@localhost:5432/ellena_beauty?schema=public"

# JWT Secret (use a strong random string — generate with: openssl rand -base64 32)
JWT_SECRET="change-this-to-a-secure-random-string"

# Frontend URL (for CORS — comma-separated for multiple origins)
FRONTEND_URL="https://yourdomain.com"
